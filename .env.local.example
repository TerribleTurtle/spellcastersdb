# SpellcastersDB Environment Variables

# Base URL for the community API data source
NEXT_PUBLIC_API_URL="https://terribleturtle.github.io/spellcasters-community-api/api/v2"

# The format for images fetched from the API (e.g., "webp" or "png")
NEXT_PUBLIC_PREFERRED_ASSET_FORMAT="webp"

# Secret token used to authenticate revalidation requests (e.g., via the /api/revalidate endpoint)
REVALIDATION_SECRET="your_revalidation_secret_here"

# Sentry DSN for error tracking and performance monitoring
NEXT_PUBLIC_SENTRY_DSN=""

# Sentry auth token for source map uploads (optional, only needed for production builds)
SENTRY_AUTH_TOKEN=""

# Upstash Redis credentials for short link sharing (optional, sharing disabled if empty)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# The base URL of the application in production (used for links and callbacks)
# Default is https://www.spellcastersdb.com if not provided
APP_URL="http://localhost:3000"

# ---------- Local Development Overrides ----------

# Toggle to serve images from a local assets folder instead of the CDN
# NEXT_PUBLIC_USE_LOCAL_ASSETS="false"

# Absolute path to a local copy of the community API all_data.json
# LOCAL_DATA_PATH=""

# Legacy fallback for LOCAL_DATA_PATH (optional, prefer LOCAL_DATA_PATH)
# LOCAL_API_PATH=""

# Absolute path to a local folder of card image assets
# LOCAL_ASSETS_PATH=""

# Dev server port used by the local API proxy (default: 3000)
# PORT="3000"

# GitHub personal access token to increase API rate limits for the /roadmap page
# GITHUB_TOKEN=""
